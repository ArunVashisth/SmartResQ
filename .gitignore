# Smart Resq - Git Ignore File
# Files and directories that should not be committed to version control

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
setup_admin.py

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.conda/

# IDE and Editors
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Project specific
# Database files
*.db
*.sqlite
*.sqlite3
archive.db

# Video and image files (keep samples, ignore large working files)
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv
*.webm
*.m4v
*.3gp
*.ts
*.mts
*.m2ts

# Large image files
*.raw
*.tiff
*.tif
*.psd
*.ai
*.eps

# Archive directories (keep structure, ignore content)
archive_analysis_*/
output_frames/
accident_photos/
vehicle_no_plates/
plate_detection_frames/
uploaded_videos/
temp/
tmp/
logs/
archives/
data/
notebooks/
scripts/

# Model files (keep architecture, ignore heavy training files)
*.h5
*.hdf5
*.pb
*.ckpt
*.pth
*.pt
model_weights.keras
*.weights
*.model

# Configuration and secrets
.env
.env.local
.env.*.local
config.ini
secrets.json
credentials.json
api_keys.txt

# Logs
*.log
logs/
log/

# OS specific
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Node.js (if any frontend builds)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# PyTorch
*.pth

# Test outputs
test_results/
test_outputs/
coverage/
.coverage
htmlcov/
.pytest_cache/

# Documentation build
docs/_build/
site/

# Backup files
*.bak
*.backup
*.old
*.orig
*.rej

# Temporary files
*.tmp
*.temp
temp/
tmp/
status.txt

# Compiled binaries
*.exe
*.dll
*.dylib
*.so.*

# Package files
*.zip
*.tar.gz
*.rar
*.7z

# Profiling
*.prof
*.lprof
.profile

# Local development
local/
dev/
development/

# Keep sample files but ignore working copies
new.mp4
sample_video.mp4
test_video.mp4

# Ignore specific large model files but keep structure
!model.json
!model.json.backup

# Ignore everything in archive directories except .gitkeep files
archive_analysis_*/*
!archive_analysis_*/.gitkeep
output_frames/*
!output_frames/.gitkeep
accident_photos/*
!accident_photos/.gitkeep
vehicle_no_plates/*
!vehicle_no_plates/.gitkeep

!frontend/public/hero-bg.mp4
