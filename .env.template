# ─────────────────────────────────────────────────────────────
#  Smart Resq – Environment Variables Template
#  Copy this to your Railway dashboard → Service → Variables
#  DO NOT commit your real .env to git
# ─────────────────────────────────────────────────────────────

# ── SERVER ──────────────────────────────────────────────────
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# ── DATABASE (MongoDB Atlas) ─────────────────────────────────
# Go to: https://cloud.mongodb.com → Your Cluster → Connect → Drivers
# Choose Python 3.6+, copy the connection string and replace <password>
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smartresq?retryWrites=true&w=majority

# ── CAMERA / VIDEO SOURCE ────────────────────────────────────
# On a cloud server, webcam index (0) won't work — use an RTSP URL
# Example: rtsp://admin:password@192.168.1.100:554/cam/realmonitor?channel=1&subtype=0
VIDEO_SOURCE=rtsp://admin:admin%40123@122.176.68.15:554/cam/realmonitor?channel=4&subtype=1
USE_LIVE_CAMERA=true

# ── DETECTION CONFIG ──────────────────────────────────────────
ACCIDENT_THRESHOLD=60.0
FRAME_SKIP=2
OCR_ENGINE=easyocr

# ── TWILIO (Emergency Voice Calls) ───────────────────────────
# Get keys from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
DESTINATION_PHONE_NUMBER=+91xxxxxxxxxx
TWILIO_TWIML_URL=https://handler.twilio.com/twiml/EHcbc30d7e5fb03b07f5c7116e0dacceaf

# ── FAST2SMS (Emergency SMS — Indian numbers) ────────────────
# Get key from: https://www.fast2sms.com/dashboard/dev-api
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# ── EMAIL / OTP (User verification) ──────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
# Generate App Password at: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your_gmail_app_password
OTP_EXPIRE_SECONDS=600
